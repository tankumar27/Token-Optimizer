GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ENABLE_LOCAL_TRANSFORMERS=0
ENABLE_LLM_LINGUA=0
LLM_LINGUA_BACKEND=llmlingua2
LLM_LINGUA2_MODEL=microsoft/llmlingua-2-bert-base-multilingual-cased-meetingbank
LLM_LINGUA2_DEVICE=cpu
LLM_LINGUA_MODEL=gemini-1.5-flash
LLM_LINGUA_TIMEOUT_SECONDS=20
DATABASE_PATH=data/app.sqlite3
